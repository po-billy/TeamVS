# 이 파일을 복사해서 ".env" 로 이름을 바꾸고 값을 채워주세요.

# [필수] 디스코드 봇 토큰 - https://discord.com/developers/applications
DISCORD_TOKEN=

# [롤 기능] Riot API 키 - https://developer.riotgames.com
# 개발용 키는 24시간마다 갱신 필요. 정식 출시 전 Production Key 신청 필수!
RIOT_API_KEY=

# [배그 기능] PUBG 공식 API 키 (무료) - https://developer.pubg.com
PUBG_API_KEY=

# [발로란트 기능] HenrikDev API 키 (무료 Basic) - https://api.henrikdev.xyz/dashboard
# 발급하려면 HenrikDev 디스코드 서버 가입 필요 (https://docs.henrikdev.xyz 참고)
HENRIK_API_KEY=

# 오버워치 기능은 OverFast API(공개)를 사용하므로 키가 필요 없습니다.

# [선택] 한국 디스코드 리스트 봇 토큰 - https://koreanbots.dev (봇 등록 후 발급)
# 하트(투표) 보상 기능과 서버 수 자동 업데이트에 사용됩니다.
KOREANBOTS_TOKEN=

# [선택] 테스트 서버 ID - 명령어가 두 개씩 보일 때(서버 전용 등록 중복)
# 이 값을 넣고 재시작하면 해당 서버의 중복 명령어가 자동 정리됩니다.
TEST_GUILD_ID=

# [선택] 봇 소유자 디스코드 유저 ID (쉼표로 여러 명 가능)
OWNER_IDS=
